# ======================================================
# AI Social Agent
# ======================================================

FROM node:24-alpine

# ======================================================
# Working Directory
# ======================================================

WORKDIR /app

# ======================================================
# Install Dependencies
# ======================================================

COPY package*.json ./

RUN npm ci

# ======================================================
# Copy Application
# ======================================================

COPY . .

# ======================================================
# Expose
# ======================================================

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -q -O - http://127.0.0.1:3000/health > /dev/null || exit 1

# ======================================================
# Start
# ======================================================

CMD ["npm", "start"]
