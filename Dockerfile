# ======================================================
# AI Social Agent
# ======================================================

FROM node:24-alpine

# ======================================================
# Working Directory
# ======================================================

WORKDIR /app

# ======================================================
# Install Dependencies
# ======================================================

COPY package*.json ./

RUN npm install

# ======================================================
# Copy Application
# ======================================================

COPY . .

# ======================================================
# Expose
# ======================================================

EXPOSE 3000

# ======================================================
# Start
# ======================================================

CMD ["npm", "start"]